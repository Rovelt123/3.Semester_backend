### =========================
### GET ALL SHIFT REQUESTS
### =========================
GET {{url}}/shift_requests
Authorization: Bearer {{token}}


### =========================
### GET SHIFT REQUEST BY ID
### =========================
GET {{url}}/shift_request/1
Authorization: Bearer {{token}}


### =========================
### CREATE SHIFT REQUEST
### =========================
POST {{url}}/shift_request/1
Authorization: Bearer {{token}}


### =========================
### DELETE SHIFT REQUEST
### =========================
DELETE {{url}}/shift_request/7
Authorization: Bearer {{token}}

### =========================
### UPDATE REQUEST
### You can update the following: status, requester_id, shift_id
### Yes, you can update multiple at a time!
### =========================
PUT {{url}}/shift_request/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "SOLVED"
}