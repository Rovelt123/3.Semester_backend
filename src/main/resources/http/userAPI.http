### =========================
### LOGIN
### =========================
POST {{url}}/users/auth/login
Content-Type: application/json

{
  "username": "Rove34lt235",
  "password": "Rovelt"
}

> {%
    var data = JSON.parse(responseBody);
    token = data.token;
%}

### =========================
### LOGOUT
### =========================
POST {{url}}/users/auth/logout
Authorization: Bearer {{token}}


### =========================
### REGISTER USER
### =========================
POST {{url}}/users/auth/register
Content-Type: application/json

{
  "name": "Rovelt",
  "username": "Rove34lt235",
  "password": "Rovelt",
  "password_repeat": "Rovelt"
}


### =========================
### GET ALL USERS
### =========================
GET {{url}}/users/users
Authorization: Bearer {{token}}


### =========================
### GET USER BY ID
### =========================
GET {{url}}/users/user/1
Authorization: Bearer {{token}}


### =========================
### GET USER BY USERNAME
### =========================
GET {{url}}/users/user/by-username/Rovelt
Authorization: Bearer {{token}}


### =========================
### UPDATE USERNAME
### =========================
PUT {{url}}/users/user/update-username
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "newUsername": "admin2",
  "password": "admin"
}


### =========================
### UPDATE PASSWORD
### =========================
PUT {{url}}/users/user/update-password
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "oldPassword": "admin",
  "newPassword": "admin2",
  "newPassword_repeat": "admin2"
}


### =========================
### DELETE USER (SELF)
### =========================
DELETE {{url}}/users/user/delete
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "password1": "Rovelt",
  "password2": "Rovelt"
}


### =========================
### FORCE DELETE USER (CHEF)
### =========================
DELETE {{url}}/users/user/force-delete/10
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "confirm_username": "Rovelt"
}