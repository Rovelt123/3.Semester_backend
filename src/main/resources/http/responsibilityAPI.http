### =========================
### GET ALL RESPONSIBILITIES
### =========================
GET {{url}}/responsibilities
Authorization: Bearer {{token}}

### =========================
### GET RESPONSIBILITY BY ID
### /responsibility/id/{name}
### =========================
GET {{url}}/responsibility/id/123
Authorization: Bearer {{token}}

### =========================
### GET RESPONSIBILITY BY NAME
### /responsibility/name/{name}
### =========================
GET {{url}}/responsibility/name/Rovelt
Authorization: Bearer {{token}}


### =========================
### CREATE RESPONSIBILITY
### /responsibility/{name}
### =========================
POST {{url}}/responsibility/Rovelt
Content-Type: application/json
Authorization: Bearer {{token}}


### =========================
### UPDATE RESPONSIBILTIY
### /responsibility/{name}/update/{new_name}
### =========================
PUT {{url}}/responsibility/Rovelt/update/Rovelt123
Authorization: Bearer {{token}}



### =========================
### DELETE RESPONSIBILITY
### /responsibility/{responsibility}
### =========================
DELETE {{url}}/responsibility/Rovelt123
Authorization: Bearer {{token}}