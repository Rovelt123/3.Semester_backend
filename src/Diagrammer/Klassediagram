@startuml

' ENUMS
enum Role {
    USER
    CHEF
}

enum HolidayStatus {
    PENDING
    APPROVED
    REJECTED
}

enum ShiftStatus {
    WAITING
    NO_RESPONSE
    APPROVED
    REJECTED
    SOLVED
}

' ENTITIES

class User {
    - int id
    - String firstname
    - String lastname
    - String username
    - String password
    - Set<Role> roles

    + addRole(Role role)
    + removeRole(Role role)

    + addResponsibility(Responsibility r)
    + removeResponsibility(Responsibility r)
}

class Responsibility {
    - int id
    - String name
}

class Holiday {
    - int id
    - LocalDate startDate
    - LocalDate endDate
    - HolidayStatus status

    + approve()
    + reject()
}

class Shift {
    - int id
    - String title
    - LocalDate date
    - LocalTime startTime
    - LocalTime endTime
}

class ShiftRequest {
    - int id
    - ShiftStatus status

    + solve()
    + addResponse(Response response)
    + removeResponse(Response response)
}

class Response {
    - int id
    - ShiftStatus status
}

class Announcement {
    - int id
    - String title
    - String content
    - LocalDateTime lastUpdated

    + updateContent(String content)
}

' RELATIONER

User "1" -- "*" Holiday : has
User "1" -- "*" Shift : owns
User "1" -- "*" Response : writes
User "1" -- "*" Announcement : creates

User "*" -- "*" Responsibility : has

Shift "1" -- "*" ShiftRequest : contains
ShiftRequest "1" -- "*" Response : has

ShiftRequest "*" -- "1" User : requester
Response "*" -- "1" User : user

ShiftRequest "*" -- "1" Shift : belongs to

@enduml